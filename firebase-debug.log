[debug] [2025-06-29T16:53:58.585Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isAuth() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return isAuth() && request.auth.uid == userId;\n    }\n\n    function isAdmin() {\n      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // User profiles\n    match /users/{userId} {\n      allow read: if isOwner(userId) || isAdmin();\n      allow create: if isAuth(); // Allow creation for any authenticated user during signup\n      allow update: if isOwner(userId) || isAdmin();\n      allow delete: if false; // Deletion should be handled by a server function\n      \n      // Subcollections\n      match /progress/{courseId} {\n        allow read, write: if isOwner(userId);\n      }\n      match /transactions/{transactionId} {\n        allow read, write: if isOwner(userId);\n      }\n    }\n\n    // Courses can be read by any authenticated user, but only written by admins.\n    match /courses/{courseId} {\n      allow read: if isAuth();\n      allow write: if isAdmin();\n    }\n    \n    // Events are public, but only writable by admins.\n    match /events/{eventId} {\n        allow read: if true;\n        allow write: if isAdmin();\n    }\n    \n    // Credit packages are readable by authenticated users, writable by admins.\n    match /credit_packages/{packageId} {\n        allow read: if isAuth();\n        allow write: if isAdmin();\n    }\n\n    // Opportunities: readable by authenticated users, writable by admins or fleet owners\n    match /opportunities/{oppId} {\n        allow read: if isAuth();\n        // Allow create for fleet/admin, update for admin\n        allow create: if isAuth() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'fleet' || isAdmin());\n        allow update: if isAdmin();\n        allow delete: if isAdmin();\n    }\n\n    // Services: readable by authenticated users, writable by admins or providers\n    match /services/{serviceId} {\n        allow read: if isAuth();\n        allow create: if isAuth() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'provider' || isAdmin());\n        allow update: if isAdmin();\n        allow delete: if isAdmin();\n    }\n  }\n}\n"}]}}
