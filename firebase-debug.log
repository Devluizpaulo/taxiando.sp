[debug] [2025-06-29T14:40:19.674Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions to make rules more readable.\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function getUserData(userId) {\n      return get(/databases/$(database)/documents/users/$(userId)).data;\n    }\n\n    function isOwner(userId) {\n      return isSignedIn() && request.auth.uid == userId;\n    }\n    \n    function isAdmin() {\n      return isSignedIn() && getUserData(request.auth.uid).role == 'admin';\n    }\n\n    function isFleet() {\n        return isSignedIn() && getUserData(request.auth.uid).role == 'fleet';\n    }\n\n    function isProvider() {\n        return isSignedIn() && getUserData(request.auth.uid).role == 'provider';\n    }\n\n    // --- COLLECTION RULES ---\n\n    // Users Collection: Users can manage their own profile. Admins have full access.\n    match /users/{userId} {\n      allow read: if isOwner(userId) || isAdmin();\n      allow create: if isSignedIn() && request.auth.uid == userId;\n      allow update: if isOwner(userId) || isAdmin();\n      \n      // Sub-collections can only be accessed by the owner.\n      match /progress/{progressId} {\n        allow read, write: if isOwner(userId);\n      }\n      match /transactions/{transactionId} {\n        allow read, write: if isOwner(userId);\n      }\n    }\n\n    // Admin-only write access collections. Any signed-in user can read them.\n    match /courses/{courseId} {\n      allow read: if isSignedIn();\n      allow create, update, delete: if isAdmin();\n    }\n    \n    match /credit_packages/{packageId} {\n        allow read: if isSignedIn();\n        allow create, update, delete: if isAdmin();\n    }\n    \n    match /events/{eventId} {\n        allow read: if isSignedIn();\n        allow create, update, delete: if isAdmin();\n    }\n\n    // Listings: Can be read by anyone, but only created/updated by specific roles or admins.\n    match /opportunities/{opportunityId} {\n        allow read: if isSignedIn();\n        allow create: if isFleet() || isAdmin();\n        allow update, delete: if isAdmin(); // Only admins can moderate/delete for now.\n    }\n\n    match /services/{serviceId} {\n        allow read: if isSignedIn();\n        allow create: if isProvider() || isAdmin();\n        allow update, delete: if isAdmin(); // Only admins can moderate/delete for now.\n    }\n  }\n}\n"}]}}
