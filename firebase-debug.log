[debug] [2025-06-29T16:10:54.783Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Public collections can be read by anyone.\n    // Only admins can write to them.\n    match /courses/{docId} {\n      allow read: if true;\n      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n    match /events/{docId} {\n      allow read: if true;\n      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n    match /credit_packages/{docId} {\n      allow read: if true;\n      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // User profiles\n    match /users/{userId} {\n      // Allow user creation. The server action handles validation, so this rule can be simple.\n      // This rule is for client-side SDKs; server admin SDK bypasses these rules.\n      // We allow creation if the new document's data has the correct uid.\n      allow create: if request.auth.uid == userId;\n\n      // Users can only read, update, or delete their OWN data.\n      allow read, update, delete: if request.auth.uid == userId;\n      \n      // An admin can read or write to any user's profile.\n      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n\n      // User subcollections (e.g., transactions, progress)\n      match /{collection}/{docId} {\n        allow read, write, delete: if request.auth.uid == userId;\n        allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n      }\n    }\n    \n    // Fleet and Provider listings\n    match /opportunities/{oppId} {\n    \tallow read: if true;\n      allow write: if request.auth != null; // Allow logged-in users to create, admin to moderate\n    }\n    \n    match /services/{serviceId} {\n    \tallow read: if true;\n      allow write: if request.auth != null; // Allow logged-in users to create, admin to moderate\n    }\n  }\n}\n"}]}}
