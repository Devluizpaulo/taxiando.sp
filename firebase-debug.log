[debug] [2025-06-29T17:22:52.933Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    match /users/{userId} {\n      // A user can create their own profile document, but only if the document ID matches their UID.\n      allow create: if request.auth != null && request.auth.uid == userId;\n      \n      // A user can read their own profile, and admins can read any profile.\n      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');\n      \n      // A user can update their own profile.\n      allow update: if request.auth.uid == userId;\n\n      // Generally, don't allow users to delete their profiles directly.\n      allow delete: if false;\n    }\n\n    match /courses/{courseId} {\n      allow read: if request.auth != null;\n      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    match /events/{eventId} {\n      allow read: if true; // Publicly readable\n      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n    \n    match /credit_packages/{packageId} {\n      allow read: if request.auth != null;\n      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n    \n    // User-specific subcollections (like progress or transactions)\n    match /users/{userId}/{collection}/{docId} {\n        allow read, write: if request.auth.uid == userId;\n    }\n\n    // Rules for opportunities and services require admin moderation\n     match /opportunities/{opportunityId} {\n      allow read: if request.auth != null;\n      // Allow creation by fleets, update by admins\n      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'fleet';\n      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    match /services/{serviceId} {\n      allow read: if request.auth != null;\n      // Allow creation by providers, update by admins\n      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'provider';\n      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n  }\n}\n"}]}}
