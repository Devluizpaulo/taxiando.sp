[debug] [2025-06-29T15:59:10.101Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions\n    function isOwner(userId) {\n      return request.auth != null && request.auth.uid == userId;\n    }\n\n    function isAdmin() {\n      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // USER PROFILES\n    match /users/{userId} {\n      // ANYONE can create a user profile document.\n      // The server action is the main gatekeeper for data validation.\n      allow create: if true;\n\n      // Users can read their own profile. Admins can read any profile.\n      allow read: if isOwner(userId) || isAdmin();\n\n      // Users can update their own profile. Admins can update any profile.\n      // We ensure core fields like role and uid cannot be changed.\n      allow update: if (isOwner(userId) || isAdmin())\n                    && request.resource.data.uid == resource.data.uid\n                    && request.resource.data.role == resource.data.role;\n\n      // No one can delete a user profile directly.\n      allow delete: if false;\n\n      // Subcollections for users\n      match /progress/{courseId} {\n        allow read, write: if isOwner(userId);\n      }\n      match /transactions/{transactionId} {\n        allow read: if isOwner(userId) || isAdmin();\n        allow create: if isAdmin(); // Only server can create transactions for now\n        allow update, delete: if false;\n      }\n    }\n\n    // COURSES\n    match /courses/{courseId} {\n      // Anyone authenticated can read courses.\n      allow read: if request.auth != null;\n      // Only admins can create, update or delete courses.\n      allow write: if isAdmin();\n    }\n    \n    // CREDIT PACKAGES\n    match /credit_packages/{packageId} {\n      // Anyone authenticated can see available packages.\n      allow read: if request.auth != null;\n      // Only admins can create, update or delete packages.\n      allow write: if isAdmin();\n    }\n\n    // EVENTS\n    match /events/{eventId} {\n      // Anyone (even unauthenticated) can see events for the homepage.\n      allow read: if true;\n      // Only admins can create, update or delete events.\n      allow write: if isAdmin();\n    }\n    \n    // OPPORTUNITIES (Fleet vehicle listings)\n    match /opportunities/{opportunityId} {\n       // Anyone authenticated can see opportunities.\n      allow read: if request.auth != null;\n      // Fleet owners can create listings. Admins can moderate.\n      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'fleet';\n      allow update: if isAdmin(); // Admin can change status (approve/reject)\n      allow delete: if isAdmin();\n    }\n    \n    // SERVICES (Provider service listings)\n     match /services/{serviceId} {\n       // Anyone authenticated can see services.\n      allow read: if request.auth != null;\n      // Providers can create listings. Admins can moderate.\n      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'provider';\n      allow update: if isAdmin(); // Admin can change status (approve/reject)\n      allow delete: if isAdmin();\n    }\n\n  }\n}\n"}]}}
