[debug] [2025-06-29T14:55:32.708Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    function isAuthOwner(userId) {\n      return request.auth != null && request.auth.uid == userId;\n    }\n\n    function isAdmin() {\n      // Check if the requesting user has an 'admin' role in their user document.\n      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    match /users/{userId} {\n      // Allow creation of a user document if the UID inside the document\n      // matches the document's ID. This is a basic sanity check that can be\n      // done without authentication, allowing the server-side signup to work.\n      // The server-side code is responsible for all other validation (e.g., one admin only).\n      allow create: if request.resource.data.uid == userId;\n\n      // Once created, only the owner or an admin can access/modify.\n      allow read: if isAuthOwner(userId) || isAdmin();\n\n      // User cannot change their own role. Admins can.\n      allow update: if (isAuthOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();\n      \n      // Only an admin can delete a user document.\n      allow delete: if isAdmin();\n    }\n    \n    // Admins can manage these collections\n    match /courses/{docId} { allow read, write: if isAdmin(); }\n    match /events/{docId} { allow read, write: if isAdmin(); }\n    match /credit_packages/{docId} { allow read, write: if isAdmin(); }\n    \n    // Authenticated users (fleets) can create opportunities, but only admins can manage all\n    match /opportunities/{docId} { \n      allow read, create: if request.auth != null;\n      allow update, delete: if isAdmin();\n    }\n    \n    // Authenticated users (providers) can create services, but only admins can manage all\n    match /services/{docId} { \n      allow read, create: if request.auth != null;\n      allow update, delete: if isAdmin();\n    }\n    \n    // Rules for user subcollections (progress, transactions, etc.)\n    match /users/{userId}/{collection}/{docId} {\n      allow read, write: if isAuthOwner(userId) || isAdmin();\n    }\n  }\n}\n"}]}}
