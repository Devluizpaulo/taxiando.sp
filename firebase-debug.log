[debug] [2025-06-29T16:34:33.034Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // USERS COLLECTION\n    // This rule allows an authenticated user to create their own user profile document.\n    // It also allows an existing user to read and update their own data,\n    // and allows an admin to read/update any user's data.\n    match /users/{userId} {\n      allow create: if request.auth != null && request.auth.uid == userId;\n      allow read, update: if request.auth != null && \n                          (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');\n      // Deletion should be handled by server-side logic for data integrity\n      allow delete: if false; \n    }\n\n    // USER SUBCOLLECTIONS\n    // Users can manage their own subcollections like progress and transactions.\n    match /users/{userId}/{userCollection}/{docId} {\n        allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n\n    // CONTENT COLLECTIONS (Courses, Events, etc.)\n    // These are publicly readable but only writable by administrators.\n    match /courses/{courseId} {\n      allow read: if true;\n      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    match /events/{eventId} {\n      allow read: if true;\n      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    match /credit_packages/{packageId} {\n      allow read: if true;\n      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // LISTING COLLECTIONS (Opportunities, Services)\n    // These are publicly readable. Creation is allowed for any authenticated user,\n    // but our server-side logic will validate if they have the correct role (fleet/provider).\n    // Updates/Deletes are restricted to the owner or an admin.\n    match /opportunities/{opportunityId} {\n      allow read: if true;\n      allow create: if request.auth != null;\n      allow update, delete: if request.auth != null && \n                             (request.auth.uid == resource.data.providerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');\n    }\n    \n    match /services/{serviceId} {\n      allow read: if true;\n      allow create: if request.auth != null;\n      allow update, delete: if request.auth != null && \n                             (request.auth.uid == resource.data.providerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');\n    }\n  }\n}\n"}]}}
