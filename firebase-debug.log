[debug] [2025-06-29T18:02:30.352Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n  \n    // Helper function to check if the user is an admin\n    function isAdmin() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    // Default deny all reads and writes\n    match /{document=**} {\n      allow read, write: if false;\n    }\n    \n    // USERS: \n    // - Allow user creation by anyone (for signup)\n    // - Authenticated users can read their own data\n    // - Authenticated users can update their own data\n    // - Admins can read/write any user document\n    match /users/{userId} {\n      allow create: if request.auth != null;\n      allow read, update: if request.auth.uid == userId || isAdmin();\n    }\n    \n    // COURSES: \n    // - Authenticated users can read all courses\n    // - Admins can create, update, and delete courses\n    match /courses/{courseId} {\n        allow read: if request.auth != null;\n        allow write: if isAdmin();\n    }\n    \n    // USER PROGRESS:\n    // - Users can read and write to their own progress subcollection\n    match /users/{userId}/progress/{courseId} {\n        allow read, write: if request.auth.uid == userId;\n    }\n\n    // EVENTS:\n    // - Anyone can read events\n    // - Admins can write events\n    match /events/{eventId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    // CREDIT PACKAGES:\n    // - Anyone can read credit packages\n    // - Admins can write credit packages\n    match /credit_packages/{packageId} {\n       allow read: if true;\n       allow write: if isAdmin();\n    }\n    \n    // COUPONS:\n    // - Only admins can read/write coupons\n    match /coupons/{couponId} {\n        allow read, write: if isAdmin();\n    }\n    \n    // NOTIFICATIONS:\n    // - Authenticated users can read notifications\n    // - Admins can create notifications\n    match /notifications/{notificationId} {\n        allow read: if request.auth != null;\n        allow create: if isAdmin();\n        allow update, delete: if false; // Prevent modification\n    }\n    \n    // SETTINGS:\n    // - Only admins can read/write settings\n    match /settings/{docId} {\n        allow read, write: if isAdmin();\n    }\n    \n    // ANALYTICS:\n    // - Reads and writes are handled by server-side logic (actions),\n    //   so client access is denied.\n     match /analytics/{docId} {\n        allow read, write: if false;\n    }\n\n    // OPPORTUNITIES & SERVICES (Classifieds)\n    // - Anyone can read listings that are 'approved' or 'Ativo'\n    // - Users can only create their own listings\n    // - Admins can write to any listing\n    function isOwner(collectionName, resourceId) {\n        return get(/databases/$(database)/documents/$(collectionName)/$(resourceId)).data.providerId == request.auth.uid;\n    }\n\n    match /opportunities/{oppId} {\n        allow read: if resource.data.status == 'Aprovado' || isAdmin();\n        allow create: if request.auth != null;\n        allow update: if isOwner('opportunities', oppId) || isAdmin();\n    }\n    \n    match /services/{serviceId} {\n        allow read: if resource.data.status == 'Ativo' || isAdmin();\n        allow create: if request.auth != null;\n        allow update: if isOwner('services', serviceId) || isAdmin();\n    }\n  }\n}\n"}]}}
