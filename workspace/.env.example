# Firebase Client SDK Configuration
# These are safe to be exposed on the client-side.
# Find these in your Firebase project settings -> General.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK Configuration
# This is a SECRET and should only be used on the server.
# This is the JSON content of the service account key file.
# Find this in Firebase project settings -> Service accounts -> Generate new private key.
# IMPORTANT: In development (.env.local), wrap the entire JSON object in single quotes.
# In production (Vercel, etc.), paste the raw JSON content as the variable value.
FIREBASE_SERVICE_ACCOUNT_JSON=''

# Google AI (Gemini) API Key
# This is a SECRET for server-side Genkit usage.
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
