# Firebase Public Keys - Find these in your Firebase Project Settings
# Go to Project Settings > General > Your apps > Firebase SDK snippet > Config
NEXT_PUBLIC_FIREBASE_API_KEY="your_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_project_id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your_project_id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id"

# Firebase Admin SDK - Server-side configuration
# Go to Project Settings > Service accounts > Generate new private key
# Copy the ENTIRE contents of the downloaded JSON file and paste it here, enclosed in single quotes.
# IMPORTANT: This key is highly sensitive. DO NOT commit it to a public repository.
# This variable is read by /src/lib/firebase-admin.ts
FIREBASE_SERVICE_ACCOUNT_JSON='<PASTE_YOUR_FIREBASE_SERVICE_ACCOUNT_JSON_HERE>'

# Google AI / Genkit - Gemini API Key
# Go to Google AI Studio (aistudio.google.com) > Get API key
NEXT_PUBLIC_GEMINI_API_KEY="your_gemini_api_key"
