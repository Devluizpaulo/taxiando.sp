# --- CHAVES PÚBLICAS (PUBLIC KEYS) ---
# Estas chaves são seguras para serem expostas no código do navegador (client-side).
# Encontre-as no seu Console do Firebase > Configurações do Projeto > Geral.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# --- CHAVES PRIVADAS (SECRET KEYS) ---
# ATENÇÃO: Estas chaves NUNCA devem ser expostas publicamente.
# Elas são usadas apenas no servidor (server-side).

# 1. Chave da Conta de Serviço do Firebase (Formato JSON)
# Essencial para o Admin SDK funcionar no backend (ações no servidor, etc.).
# Vá para seu Console do Firebase > Configurações do Projeto > Contas de Serviço.
# Clique em "Gerar nova chave privada". Copie o CONTEÚDO COMPLETO do arquivo JSON baixado e cole AQUI, dentro das aspas simples.
# IMPORTANTE: O conteúdo JSON deve ser colado diretamente na mesma linha.
FIREBASE_SERVICE_ACCOUNT_JSON=''

# 2. Chave de API do Google AI (Gemini)
# Necessária para as funcionalidades de Inteligência Artificial com Genkit.
# Vá para o Google AI Studio (aistudio.google.com), crie uma API Key e cole aqui.
GOOGLE_AI_API_KEY=""
