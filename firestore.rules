rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if request.auth.uid == userId; // Allows a user to create their own doc
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      
      match /transactions/{transactionId} {
        allow read: if isAuth() && request.auth.uid == userId || isAdmin();
        allow create: if isAdmin(); // Only trusted server/admin can create transactions
      }
      
      match /progress/{courseId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }
    
    // Public read, admin write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /credit_packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /opportunities/{oppId} {
      allow read, write: if isAuth();
    }
    
    match /services/{serviceId} {
      allow read, write: if isAuth();
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /analytics/{analyticId} {
      allow read: if isAdmin();
      // Write access is handled by server-side actions with admin credentials, which bypass these rules.
      allow write: if false; 
    }
  }
}
