
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Public collections can be read by anyone.
    // Only admins can write to them.
    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /events/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /credit_packages/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      // Allow user creation. The server action handles validation, so this rule can be simple.
      // This rule is for client-side SDKs; server admin SDK bypasses these rules.
      // We allow creation if the new document's data has the correct uid.
      allow create: if request.auth.uid == userId;

      // Users can only read, update, or delete their OWN data.
      allow read, update, delete: if request.auth.uid == userId;
      
      // An admin can read or write to any user's profile.
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // User subcollections (e.g., transactions, progress)
      match /{collection}/{docId} {
        allow read, write, delete: if request.auth.uid == userId;
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }
    
    // Fleet and Provider listings
    match /opportunities/{oppId} {
    	allow read: if true;
      allow write: if request.auth != null; // Allow logged-in users to create, admin to moderate
    }
    
    match /services/{serviceId} {
    	allow read: if true;
      allow write: if request.auth != null; // Allow logged-in users to create, admin to moderate
    }
  }
}
