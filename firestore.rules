
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      // A user can create their own profile document, but only if the document ID matches their UID.
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // A user can read their own profile, and admins can read any profile.
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // A user can update their own profile.
      allow update: if request.auth.uid == userId;

      // Generally, don't allow users to delete their profiles directly.
      allow delete: if false;
    }

    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /events/{eventId} {
      allow read: if true; // Publicly readable
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /credit_packages/{packageId} {
      allow read: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // User-specific subcollections (like progress or transactions)
    match /users/{userId}/{collection}/{docId} {
        allow read, write: if request.auth.uid == userId;
    }

    // Rules for opportunities and services require admin moderation
     match /opportunities/{opportunityId} {
      allow read: if request.auth != null;
      // Allow creation by fleets, update by admins
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'fleet';
      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /services/{serviceId} {
      allow read: if request.auth != null;
      // Allow creation by providers, update by admins
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'provider';
      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
