rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Check the user's role from their own user document.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Allow user creation by anyone. This is necessary for server-side sign-up actions.
      // Security is handled by the server action logic itself.
      allow create: if true;

      // A user can read/update their own data. An admin can read/update any user's data.
      allow read, update: if isOwner(userId) || isAdmin();

      // No one can delete user accounts through the client.
      allow delete: if false;

      // Allow users to access their own subcollections (e.g., progress, transactions)
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Rules for other collections
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /credit_packages/{packageId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    match /events/{eventId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }

    match /services/{listingId} {
        allow read: if resource.data.status == 'Aprovado';
        allow create: if request.auth.uid == request.resource.data.providerId;
        allow update, delete: if request.auth.uid == resource.data.providerId || isAdmin();
    }

     match /opportunities/{listingId} {
        allow read: if resource.data.status == 'Aprovado';
        allow create: if request.auth.uid == request.resource.data.providerId; // Assuming fleet user is provider
        allow update, delete: if request.auth.uid == resource.data.providerId || isAdmin();
    }
  }
}
