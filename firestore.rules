rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    // This rule allows an authenticated user to create their own user profile document.
    // It also allows an existing user to read and update their own data,
    // and allows an admin to read/update any user's data.
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update: if request.auth != null && 
                          (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Deletion should be handled by server-side logic for data integrity
      allow delete: if false; 
    }

    // USER SUBCOLLECTIONS
    // Users can manage their own subcollections like progress and transactions.
    match /users/{userId}/{userCollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // CONTENT COLLECTIONS (Courses, Events, etc.)
    // These are publicly readable but only writable by administrators.
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /credit_packages/{packageId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // LISTING COLLECTIONS (Opportunities, Services)
    // These are publicly readable. Creation is allowed for any authenticated user,
    // but our server-side logic will validate if they have the correct role (fleet/provider).
    // Updates/Deletes are restricted to the owner or an admin.
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
                             (request.auth.uid == resource.data.providerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    match /services/{serviceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
                             (request.auth.uid == resource.data.providerId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
