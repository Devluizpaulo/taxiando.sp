rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection
    match /users/{userId} {
      // ANYONE can create a user document IF they are the authenticated user.
      // This is necessary for the registration flow.
      allow create: if request.auth.uid == userId;

      // A user can READ their own profile. Admins can read anyone's profile.
      allow read: if request.auth.uid == userId || isAdmin();

      // A user can UPDATE their own profile, but CANNOT change their role.
      // Admins can update any field on any user profile.
      allow update: if (request.auth.uid == userId && request.resource.data.role == resource.data.role) || isAdmin();

      // Only admins can delete users.
      allow delete: if isAdmin();

      // Transactions subcollection
      match /transactions/{transactionId} {
        allow read, create: if request.auth.uid == userId;
      }
      
      // Progress subcollection
      match /progress/{courseId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Global data collections (Courses, Events, etc.)
    match /{collection}/{docId} {
    	// Allow any authenticated user to read public data like courses, events, etc.
      allow read: if request.auth != null;
      
      // Only admins can create, update, or delete global data.
      allow write: if isAdmin();
    }

    // Specific rules for collections that need different logic
    
    // Opportunities can be read by any authenticated user.
    // They are created/updated via server-side logic, so client-side write is denied.
    match /opportunities/{opportunityId} {
    	allow read: if request.auth != null;
      allow write: if false; // Managed by server actions
    }

    // Services can be read by any authenticated user.
    // They are created/updated via server-side logic.
    match /services/{serviceId} {
    	allow read: if request.auth != null;
      allow write: if false; // Managed by server actions
    }
  }
}
