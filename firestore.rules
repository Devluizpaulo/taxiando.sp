rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection:
    // - Anyone can create their own user document upon signup.
    // - Users can only read, update, or delete their own document.
    match /users/{userId} {
      allow create: if request.auth.uid != null;
      allow read, update, delete: if request.auth.uid == userId;
    }

    // Add rules for other collections here as the app grows.
    // For example, for a 'cars' collection owned by a fleet:
    // match /cars/{carId} {
    //   allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Frota';
    // }
  }
}
