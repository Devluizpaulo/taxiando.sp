rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Temporarily open user creation to unblock registration flow.
      // After creating the admin user, it's recommended to tighten this rule.
      allow create; 
      
      // Users can read/update/delete their own profile. Admins can do it too.
      allow read, update, delete: if request.auth.uid == userId || 
                                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Courses collection
    match /courses/{courseId} {
      allow read;
      allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User progress sub-collection
    match /users/{userId}/progress/{courseId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Events collection
    match /events/{eventId} {
      allow read;
      allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Credit packages collection
    match /credit_packages/{packageId} {
      allow read;
      allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User transactions sub-collection
      match /users/{userId}/transactions/{transactionId} {
        allow read, write: if request.auth.uid == userId;
    }

    // Opportunities collection (for vehicle rentals)
    match /opportunities/{opportunityId} {
      allow read;
      // Creation allowed by fleet or admin roles
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['fleet', 'admin'];
      // Update/delete by owner or admin
      allow update, delete: if resource.data.fleetId == request.auth.uid || 
                              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Services collection (for service providers)
    match /services/{serviceId} {
        allow read;
        // Creation allowed by provider or admin roles
        allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['provider', 'admin'];
        // Update/delete by owner or admin
        allow update, delete: if resource.data.providerId == request.auth.uid || 
                                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
